<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>STORM: {{ topic }}</title>
  <style>
    body { font-family: 'Segoe UI', sans-serif; max-width: 960px; margin: 0 auto; padding: 2rem; color: #333; }
    h1  { color: #1a1a2e; border-bottom: 3px solid #e94560; padding-bottom: .5rem; }
    h2  { color: #16213e; margin-top: 2rem; }
    .meta { color: #666; font-size: .9rem; margin-bottom: 2rem; }
    .persona-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
    .persona-card { background: #f8f9fa; border-left: 4px solid #e94560; padding: 1rem; border-radius: 4px; }
    .persona-card.timeout { border-left-color: #ccc; background: #f0f0f0; color: #888; }
    .persona-card h3 { margin: 0 0 .5rem; }
    .badge { background: #1a1a2e; color: #fff; padding: 2px 8px; border-radius: 12px; font-size: .75rem; margin-right: 4px; }
    .contradiction { background: #fff3cd; border-left: 4px solid #ffc107; padding: 1rem; margin: .5rem 0; border-radius: 4px; }
    .synthesis   { background: #e8f5e9; padding: 1.5rem; border-radius: 8px; }
    .peer-review { background: #fce4ec; padding: 1.5rem; border-radius: 8px; }
    hr { margin: 2rem 0; border: none; border-top: 1px solid #eee; }
  </style>
</head>
<body>
  <h1>&#128202; STORM Research Report</h1>
  <div class="meta">
    <strong>Topic:</strong> {{ topic }} &nbsp;|&nbsp;
    <strong>Generated:</strong> {{ generated_at }} &nbsp;|&nbsp;
    <strong>Method:</strong> Stanford STORM (Shao et al., NAACL 2024)
  </div>

  <h2>&#129309; Step 1: Multi-Perspective Analysis</h2>
  <div class="persona-grid">
    {% for p in personas %}
    <div class="persona-card{% if p.timed_out %} timeout{% endif %}">
      <h3><span class="badge">{{ p.llm }}</span> {{ p.role }}</h3>
      {% if p.timed_out %}
        <p>&#9888;&#65039; 응답 없음 (타임아웃)</p>
      {% else %}
        {{ p.content | safe }}
      {% endif %}
    </div>
    {% endfor %}
  </div>

  <h2>&#9889; Step 2: Contradictions &amp; Tensions</h2>
  <div class="contradiction">{{ contradictions | safe }}</div>

  <h2>&#128279; Step 3: Synthesis</h2>
  <div class="synthesis">{{ synthesis | safe }}</div>

  <h2>&#128269; Step 4: Peer Review</h2>
  <div class="peer-review">{{ peer_review | safe }}</div>

  <hr>
  <p style="color:#999;font-size:.8rem;">Generated by STORM Research Skill &mdash; KECC-ResearchLab</p>
</body>
</html>
